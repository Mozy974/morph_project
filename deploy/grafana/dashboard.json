{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Tracing Overview (Tempo Traces)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(tempo_distributor_spans_received_total[5m]))", "legendFormat": "Spans OTLP / sec" }
      ]
    },
    {
      "title": "Cache Latency (p99)",
      "type": "heatmap",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(cache_latency_seconds_bucket[5m]))", "legendFormat": "p99 Cache Latency" }
      ]
    },
    {
      "title": "Tempo Storage Traces Received",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "max": 10000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 9000 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "tempo_ingester_traces_received_total", "legendFormat": "Traces Recues" }
      ]
    },
    {
      "title": "RGPD Violations",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "expr": "sum(increase(rgpd_violation_total[1h])) by (violation_type)", "legendFormat": "Violations" }
      ]
    },
    {
      "title": "Agent Performance",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "expr": "rate(agent_processing_time_seconds_sum[5m]) / rate(agent_processing_time_seconds_count[5m])", "legendFormat": "Temps de Réponse Moy. (s)" }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["superagent", "morph", "sre", "mission-critical"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "SuperAgent Morph — Mission Critical Advanced Dashboard"
}
